{
  "name": "aikido-site",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "astro dev",
    "clean": "node ./scripts/clean-build.mjs",
    "generate:brochures": "node ./scripts/generate-brochures.mjs",
    "build": "npm run clean && npm run generate:brochures && astro build",
    "preview": "astro preview",
    "worker:dev": "npm run build && wrangler dev",
    "worker:deploy": "npm run build && wrangler deploy"
  },
  "devDependencies": {
    "astro": "^6.2.1",
    "wrangler": "^4.14.1"
  },
  "dependencies": {
    "astro-icon": "^1.1.5",
    "lucide": "^1.14.0",
    "lucide-react": "^1.14.0",
    "lucide-static": "^1.14.0"
  }
}
