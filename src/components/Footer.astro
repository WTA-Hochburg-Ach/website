---
import {
  contactData,
  footerLinks,
  footerSocialLinks,
  partnerLinks,
  trainingSchedule,
  venue,
} from '../data/site';

import { Icon } from "astro-icon/components";

const baseUrl = import.meta.env.BASE_URL || '/';
const currentYear = new Date().getFullYear();
const withBase = (path = '') => `${baseUrl}${path}`;

const footerLabelFallbacks = {
  'nav.about': 'Ueber uns',
  'nav.training': 'Training',
  'nav.schedule': 'Trainingsplan',
  'nav.contact': 'Kontakt',
  'footer.news_and_events': 'Aktuelles & Termine',
  'footer.event_overview': 'Terminuebersicht',
  'nav.gallery': 'Galerie',
  'footer.legal_and_privacy': 'Impressum & Datenschutz',
};
---

<footer class="footer">
  <div class="footer-content">
    <div class="footer-grid">
      {footerLinks.map((section) => (
        <div class="footer-section">
          <h4 data-i18n={section.titleKey}>
            {section.titleKey === 'footer.dojo_title' ? 'WTA Hochburg-Ach' : 'Aktuelles'}
          </h4>

          <ul>
            {section.items.map((item) => (
              <li>
                <a href={withBase(item.href)} data-i18n={item.labelKey}>
                  {footerLabelFallbacks[item.labelKey as keyof typeof footerLabelFallbacks]}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}

      <div class="footer-section">
        <h4 data-i18n="footer.times_title">Trainingszeiten</h4>
        <ul>
          {trainingSchedule.map((item, index) => (
            <li
              data-i18n={
                index === 0
                  ? 'footer.times_monday'
                  : index === 1
                    ? 'footer.times_friday_questions'
                    : index === 2
                      ? 'footer.times_friday_training'
                      : 'footer.times_saturday'
              }
            >
              {item.day}: {item.time} {item.label}
            </li>
          ))}
        </ul>
      </div>

      <div class="footer-section">
        <h4 data-i18n="footer.contact_title">Kontakt</h4>
        <ul>
          <li><a href={`mailto:${contactData.email}`}>{contactData.email}</a></li>
          <li><a href={contactData.phone.href}>{contactData.phone.compact}</a></li>
          <li data-i18n="footer.address_line1">{venue.street}</li>
          <li data-i18n="footer.address_line2">{venue.postalCode} {venue.city}</li>
        </ul>

        <div class="footer-social">
          {footerSocialLinks.map((item) => (
            <a
              href={item.href}
              aria-label={item.label}
              target={item.external || item.href.startsWith('http') ? '_blank' : undefined}
              rel={item.external || item.href.startsWith('http') ? 'noopener noreferrer' : undefined}
            >
              <Icon name={item.icon} size="24" />
            </a>
          ))}
        </div>
      </div>
    </div>
  </div>

  <img src={`${baseUrl}assets/brush.svg`} alt="" class="footer-brush" />

  <div class="footer-bottom">
    <p data-i18n="footer.copyright" data-i18n-attr="data-year:footer.year" data-year={currentYear}>
      © {currentYear} Wanomichi Takemusu Aikido Hochburg-Ach
    </p>
    <p class="footer-tagline" data-i18n="footer.tagline">Aikido - der Weg der Harmonie</p>
  </div>
</footer>


<style>
.footer-social a {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 40px;
  height: 40px;
}

.footer-social svg {
  opacity: 0.8;
  transition: 0.2s;
}

.footer-social a:hover svg {
  opacity: 1;
  transform: scale(1.15);
}

</style>