---
import {
  contactData,
  footerLinks,
  footerSocialLinks,
  partnerLinks,
  trainingSchedule,
  venue,
} from '../data/site';

const baseUrl = import.meta.env.BASE_URL || '/';
const currentYear = new Date().getFullYear();
const withBase = (path = '') => `${baseUrl}${path}`;

const footerLabelFallbacks = {
  'nav.about': 'Ueber uns',
  'nav.training': 'Training',
  'nav.schedule': 'Trainingsplan',
  'nav.contact': 'Kontakt',
  'footer.news_and_events': 'Aktuelles & Termine',
  'footer.event_overview': 'Terminuebersicht',
  'nav.gallery': 'Galerie',
  'footer.legal_and_privacy': 'Impressum & Datenschutz',
};
---

<footer class="footer">
  <div class="footer-content">
    <div class="footer-grid">
      {footerLinks.map((section) => (
        <div class="footer-section">
          <h4 data-i18n={section.titleKey}>
            {section.titleKey === 'footer.dojo_title' ? 'WTA Hochburg-Ach' : 'Aktuelles'}
          </h4>

          <ul>
            {section.items.map((item) => (
              <li>
                <a href={withBase(item.href)} data-i18n={item.labelKey}>
                  {footerLabelFallbacks[item.labelKey as keyof typeof footerLabelFallbacks]}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}

      <div class="footer-section">
        <h4 data-i18n="footer.times_title">Trainingszeiten</h4>
        <ul>
          {trainingSchedule.map((item, index) => (
            <li
              data-i18n={
                index === 0
                  ? 'footer.times_monday'
                  : index === 1
                    ? 'footer.times_friday_questions'
                    : index === 2
                      ? 'footer.times_friday_training'
                      : 'footer.times_saturday'
              }
            >
              {item.day}: {item.time} {item.label}
            </li>
          ))}
        </ul>
      </div>

      <div class="footer-section">
        <h4 data-i18n="footer.contact_title">Kontakt</h4>
        <ul>
          <li><a href={`mailto:${contactData.email}`}>{contactData.email}</a></li>
          <li><a href={contactData.phone.href}>{contactData.phone.compact}</a></li>
          <li data-i18n="footer.address_line1">{venue.street}</li>
          <li data-i18n="footer.address_line2">{venue.postalCode} {venue.city}</li>
        </ul>

        <div class="footer-social">
          {footerSocialLinks.map((item) => (
            <a
              href={item.href}
              aria-label={item.label}
              target={item.external || item.href.startsWith('http') ? '_blank' : undefined}
              rel={item.external || item.href.startsWith('http') ? 'noopener noreferrer' : undefined}
            >
              {item.icon === 'lucide:mail' && (
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="24" height="24">
                  <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
                  <polyline points="22,6 12,13 2,6"/>
                </svg>
              )}
              {item.icon === 'lucide:phone' && (
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="24" height="24">
                  <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
                </svg>
              )}
              {item.icon === 'lucide:instagram' && (
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="24" height="24">
                  <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
                  <path d="m16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/>
                  <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>
                </svg>
              )}
              {item.icon === 'lucide:facebook' && (
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="24" height="24">
                  <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/>
                </svg>
              )}
            </a>
          ))}
        </div>
      </div>
    </div>
  </div>

  <img src={`${baseUrl}assets/brush.svg`} alt="" class="footer-brush" />

  <div class="footer-bottom">
    <p data-i18n="footer.copyright" data-i18n-attr="data-year:footer.year" data-year={currentYear}>
      © {currentYear} Wanomichi Takemusu Aikido Hochburg-Ach
    </p>
    <p class="footer-tagline" data-i18n="footer.tagline">Aikido - der Weg der Harmonie</p>
  </div>
</footer>


<style>
.footer-social a {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 40px;
  height: 40px;
}

.footer-social svg {
  opacity: 0.8;
  transition: 0.2s;
}

.footer-social a:hover svg {
  opacity: 1;
  transform: scale(1.15);
}

</style>