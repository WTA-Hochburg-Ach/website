---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, type CollectionEntry } from 'astro:content';
import { formatDateRange } from '../../lib/news';

type NewsPageProps = {
  entry: CollectionEntry<'news'>;
};

export async function getStaticPaths() {
  const entries = await getCollection('news');

  return entries.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props as NewsPageProps;
const { Content } = await entry.render();
const baseUrl = import.meta.env.BASE_URL || '/';
---

<BaseLayout title={entry.data.title} description={entry.data.preview}>
  <article class="content-block-spacious news-article">
    <p class="news-back">
      <a href={`${baseUrl}news`} class="button button-outline">Zur Uebersicht</a>
    </p>

    <div class="news-header-meta">
      <span class="event-date">{formatDateRange(entry.data.date, entry.data.endDate)}</span>
      <span class:list={['entry-type', entry.data.type === 'event' ? 'entry-type-event' : 'entry-type-news']}>
        {entry.data.type === 'event' ? 'Termin' : 'Aktuelles'}
      </span>
    </div>

    <h1>{entry.data.title}</h1>
    {entry.data.location && <p class="news-location">{entry.data.location}</p>}
    {entry.data.preview && <p class="lead-text">{entry.data.preview}</p>}

    {(entry.data.pdfs?.de || entry.data.pdfs?.en) && (
      <div class="news-actions">
        {entry.data.pdfs?.de && (
          <a href={entry.data.pdfs.de} class="button button-primary" target="_blank" rel="noopener">
            PDF Deutsch
          </a>
        )}

        {entry.data.pdfs?.en && (
          <a href={entry.data.pdfs.en} class="button button-outline" target="_blank" rel="noopener">
            PDF English
          </a>
        )}

        <a
          href={entry.data.pdfs?.de || entry.data.pdfs?.en || '#'}
          class="button button-outline"
          target="_blank"
          rel="noopener"
        >
          Vorschau
        </a>
      </div>
    )}

    <div class="news-article-content">
      <Content />
    </div>
  </article>
</BaseLayout>

<style>
.news-article {
  max-width: 900px;
}

.news-back {
  margin-bottom: 1.5rem;
}

.news-header-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 0.55rem;
  align-items: center;
  margin-bottom: 1rem;
}

.news-location {
  margin-bottom: 1rem;
  font-size: 1rem;
  font-weight: 700;
  color: var(--color-text-muted);
}

.entry-type {
  display: inline-flex;
  align-items: center;
  padding: 0.3rem 0.7rem;
  border-radius: 999px;
  font-size: 0.78rem;
  font-weight: 800;
  letter-spacing: 0.05em;
  text-transform: uppercase;
}

.entry-type-event {
  background: rgba(86, 112, 79, 0.12);
  color: var(--color-primary-dark);
}

.entry-type-news {
  background: rgba(188, 162, 112, 0.16);
  color: var(--color-accent-dark);
}

.news-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 0.75rem;
  margin: 2rem 0;
}

.news-article-content {
  margin-top: 2rem;
}
</style>
