---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { formatDateRange, isEvent, sortByDateAscending, sortByDateDescending } from '../lib/news';

const baseUrl = import.meta.env.BASE_URL || '/';
const withBase = (path = '') => `${baseUrl}${path}`;
const allEntries = sortByDateDescending(await getCollection('news'));
const featuredEvents = sortByDateAscending(allEntries.filter(isEvent)).slice(0, 3);
---

<BaseLayout title="Aktuelles & Termine">
  <section class="content-block-spacious news-page-intro">
    <h1>Aktuelles & Termine</h1>
    <p class="lead-text">Kurze Neuigkeiten, kommende Lehrgaenge und die gesamte Chronik findest du hier in einer gemeinsamen Uebersicht.</p>
    <p>Alle Eintraege sind chronologisch nach Datum geordnet. Termine fuehren zu ihrer Ausschreibung oder zu einer Detailseite, kurze News bleiben kompakt und schnell lesbar.</p>
  </section>

  {featuredEvents.length > 0 && (
    <section class="content-block-spacious">
      <h2>Kommende Termine</h2>
      <div class="feature-grid featured-event-grid">
        {featuredEvents.map((item) => (
          <article class:list={['feature-card', 'featured-event-card', `tone-${item.data.color}`]}>
            <span class="event-date">{formatDateRange(item.data.date, item.data.endDate)}</span>
            <h3>{item.data.title}</h3>
            {item.data.location && <p class="event-location">{item.data.location}</p>}
            <p>{item.data.preview}</p>
            <a class="read-more-btn" href={withBase(`news/${item.slug}`)}>Weiter lesen</a>
          </article>
        ))}
      </div>
    </section>
  )}

  <section class="content-block-spacious">
    <h2>Chronik</h2>
    <div class="chronicle-list">
      {allEntries.map((item) => (
        <article class:list={['chronicle-card', `tone-${item.data.color}`]}>
          <div>
            <div class="chronicle-meta">
              <span class="event-date">{formatDateRange(item.data.date, item.data.endDate)}</span>
              <span class:list={['entry-type', item.data.type === 'event' ? 'entry-type-event' : 'entry-type-news']}>
                {item.data.type === 'event' ? 'Termin' : 'Aktuelles'}
              </span>
            </div>

            <div class="chronicle-copy">
              <h3>{item.data.title}</h3>
              {item.data.location && <p class="event-location">{item.data.location}</p>}
              <p>{item.data.preview}</p>
            </div>
          </div>

          <div class="chronicle-actions">
            <a class="read-more-btn" href={withBase(`news/${item.slug}`)}>Weiter lesen</a>
          </div>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>

<style>
.news-page-intro {
  padding-bottom: 0;
}

.featured-event-grid {
  align-items: stretch;
}

.featured-event-card,
.chronicle-card {
  border-left: 4px solid transparent;
}

.chronicle-list {
  display: grid;
  gap: 1rem;
}

.chronicle-card {
  display: grid;
  grid-template-columns: minmax(0, 1fr) auto;
  gap: 1.25rem;
  align-items: center;
  padding: 1.5rem;
  border-radius: 24px;
  background: var(--color-surface);
  border: 1px solid var(--color-border-light);
  box-shadow: var(--shadow-sm);
}

.chronicle-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 0.55rem;
  align-items: center;
  margin-bottom: 0.85rem;
}

.chronicle-copy h3 {
  margin-bottom: 0.6rem;
}

.chronicle-copy p {
  margin: 0;
}

.event-location {
  font-size: 0.96rem;
  font-weight: 700;
  color: var(--color-text-muted);
}

.entry-type {
  display: inline-flex;
  align-items: center;
  padding: 0.3rem 0.7rem;
  border-radius: 999px;
  font-size: 0.78rem;
  font-weight: 800;
  letter-spacing: 0.05em;
  text-transform: uppercase;
}

.entry-type-event {
  background: rgba(86, 112, 79, 0.12);
  color: var(--color-primary-dark);
}

.entry-type-news {
  background: rgba(188, 162, 112, 0.16);
  color: var(--color-accent-dark);
}

.tone-moss {
  border-left-color: #56704f;
}

.tone-sage {
  border-left-color: #90a388;
}

.tone-gold {
  border-left-color: #bca270;
}

@media (max-width: 820px) {
  .chronicle-card {
    grid-template-columns: 1fr;
  }
}
</style>
