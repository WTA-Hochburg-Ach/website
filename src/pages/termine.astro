---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import {
  buildMonthLabel,
  formatDateRange,
  getMonthMatrix,
  isEvent,
  monthKey,
  sortByDateAscending,
} from '../lib/news';

const baseUrl = import.meta.env.BASE_URL || '/';
const withBase = (path = '') => `${baseUrl}${path}`;
const events = sortByDateAscending((await getCollection('news')).filter(isEvent));

const groupedMonths = events.reduce((accumulator, entry) => {
  const key = monthKey(entry.data.date);
  const current = accumulator.get(key) ?? [];
  current.push(entry);
  accumulator.set(key, current);
  return accumulator;
}, new Map());

const calendarMonths = [...groupedMonths.entries()].map(([key, entries]) => {
  const referenceDate = new Date(entries[0].data.date.getFullYear(), entries[0].data.date.getMonth(), 1);
  const entriesByDay = entries.reduce((accumulator, entry) => {
    const day = entry.data.date.getDate();
    const list = accumulator.get(day) ?? [];
    list.push(entry);
    accumulator.set(day, list);
    return accumulator;
  }, new Map());

  return {
    key,
    label: buildMonthLabel(referenceDate),
    weeks: getMonthMatrix(referenceDate),
    entriesByDay,
  };
});
---

<BaseLayout title="Termine">
  <section class="content-block-spacious news-page-intro">
    <h1>Termine</h1>
    <p class="lead-text">Kalender, Timeline und Ausschreibungen fuer Lehrgaenge und besondere Trainings findest du gesammelt auf dieser Seite.</p>
    <p>Kurze Informationen erscheinen direkt im Kalender. Je nach Termin oeffnet sich ein Popup oder eine eigene Detailseite mit PDF-Vorschau und Download.</p>
  </section>

  <section class="content-block-spacious">
    <h2>Kalender</h2>

    <div class="calendar-grid">
      {calendarMonths.map((month) => (
        <article class="calendar-month">
          <header class="calendar-month-header">
            <h3>{month.label}</h3>
          </header>

          <div class="calendar-weekdays">
            <span>Mo</span>
            <span>Di</span>
            <span>Mi</span>
            <span>Do</span>
            <span>Fr</span>
            <span>Sa</span>
            <span>So</span>
          </div>

          <div class="calendar-weeks">
            {month.weeks.map((week) => (
              <div class="calendar-week">
                {week.map((day) => {
                  const dayEntries = day ? month.entriesByDay.get(day) ?? [] : [];

                  return (
                    <div class:list={['calendar-day', dayEntries.length > 0 && 'calendar-day-active']}>
                      {day ? <span class="calendar-day-number">{day}</span> : <span class="calendar-day-number calendar-day-empty"></span>}

                      {dayEntries.map((entry) =>
                        entry.data.display === 'page' ? (
                          <a
                            href={withBase(`news/${entry.slug}`)}
                            class:list={['calendar-entry', `tone-${entry.data.color}`]}
                          >
                            <strong>{entry.data.title}</strong>
                            <span>{entry.data.preview}</span>
                          </a>
                        ) : (
                          <button
                            class:list={['calendar-entry', `tone-${entry.data.color}`]}
                            type="button"
                            data-modal-trigger
                            data-slug={entry.slug}
                            data-title={entry.data.title}
                            data-date={entry.data.date.toISOString()}
                            data-end-date={entry.data.endDate?.toISOString() ?? ''}
                          >
                            <strong>{entry.data.title}</strong>
                            <span>{entry.data.preview}</span>
                          </button>
                        ),
                      )}
                    </div>
                  );
                })}
              </div>
            ))}
          </div>
        </article>
      ))}
    </div>
  </section>

  <section class="content-block-spacious">
    <h2>Timeline</h2>
    <div class="horizontal-timeline news-rail">
      {events.map((entry) =>
        entry.data.display === 'page' ? (
          <a class:list={['timeline-event', 'news-card', `tone-${entry.data.color}`]} href={withBase(`news/${entry.slug}`)}>
            <div class="news-card-tags">
              <span class="event-date">{formatDateRange(entry.data.date, entry.data.endDate)}</span>
              <span class="news-mode-tag">Seite</span>
            </div>
            <h3>{entry.data.title}</h3>
            {entry.data.location && <p class="event-location">{entry.data.location}</p>}
            <p>{entry.data.preview}</p>
            <span class="read-more-btn">Weiter lesen</span>
          </a>
        ) : (
          <button
            class:list={['timeline-event', 'news-card', 'news-card-button', `tone-${entry.data.color}`]}
            type="button"
            data-modal-trigger
            data-slug={entry.slug}
            data-title={entry.data.title}
            data-date={entry.data.date.toISOString()}
            data-end-date={entry.data.endDate?.toISOString() ?? ''}
          >
            <div class="news-card-tags">
              <span class="event-date">{formatDateRange(entry.data.date, entry.data.endDate)}</span>
              <span class="news-mode-tag">Popup</span>
            </div>
            <h3>{entry.data.title}</h3>
            {entry.data.location && <p class="event-location">{entry.data.location}</p>}
            <p>{entry.data.preview}</p>
            <span class="read-more-btn">Weiter lesen</span>
          </button>
        ),
      )}
    </div>
  </section>

  <div id="news-modal" class="modal" aria-hidden="true">
    <div class="modal-backdrop" data-modal-close></div>
    <div class="modal-content">
      <button class="modal-close" type="button" data-modal-close>&times;</button>
      <div class="modal-header">
        <h2 id="modal-title"></h2>
        <span id="modal-date"></span>
      </div>
      <div class="modal-body" id="modal-body">
        <div class="loader">Laden...</div>
      </div>
    </div>
  </div>
</BaseLayout>

<script is:inline define:vars={{ baseUrl }}>
  const modal = document.getElementById('news-modal');
  const modalTitle = document.getElementById('modal-title');
  const modalDate = document.getElementById('modal-date');
  const modalBody = document.getElementById('modal-body');

  function formatModalDate(startDate, endDate) {
    const start = new Date(startDate);
    const end = endDate ? new Date(endDate) : null;

    if (!endDate || Number.isNaN(end?.getTime())) {
      return start.toLocaleDateString('de-DE', {
        year: 'numeric',
        month: 'long',
        day: 'numeric',
      });
    }

    const sameMonth = start.getFullYear() === end.getFullYear() && start.getMonth() === end.getMonth();
    if (sameMonth) {
      return `${start.getDate()}.-${end.getDate()}. ${start.toLocaleDateString('de-DE', { month: 'long', year: 'numeric' })}`;
    }

    return `${start.toLocaleDateString('de-DE')} - ${end.toLocaleDateString('de-DE')}`;
  }

  async function openNewsModal(trigger) {
    const slug = trigger.getAttribute('data-slug');
    const title = trigger.getAttribute('data-title');
    const date = trigger.getAttribute('data-date');
    const endDate = trigger.getAttribute('data-end-date');

    if (!slug || !title || !date || !modal || !modalBody || !modalTitle || !modalDate) {
      return;
    }

    modalTitle.textContent = title;
    modalDate.textContent = formatModalDate(date, endDate);
    modalBody.innerHTML = '<div class="loader">Laden...</div>';
    modal.classList.add('show');
    modal.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';

    try {
      const response = await fetch(`${baseUrl}news/${slug}.json`);
      const news = await response.json();
      const actions = [];

      if (news.pdfs?.de) {
        actions.push(`<a href="${news.pdfs.de}" class="button button-primary" target="_blank" rel="noopener">PDF Deutsch</a>`);
      }

      if (news.pdfs?.en) {
        actions.push(`<a href="${news.pdfs.en}" class="button button-outline" target="_blank" rel="noopener">PDF English</a>`);
      }

      if (news.pdfs?.de || news.pdfs?.en) {
        const previewHref = news.pdfs?.de || news.pdfs?.en;
        actions.push(`<a href="${previewHref}" class="button button-outline" target="_blank" rel="noopener">Vorschau</a>`);
      }

      modalBody.innerHTML = `
        ${news.location ? `<p class="modal-location">${news.location}</p>` : ''}
        ${actions.length > 0 ? `<div class="modal-actions">${actions.join('')}</div>` : ''}
        <div class="prose-lg">${news.content}</div>
      `;
      modalBody.classList.add('content-visible');
    } catch (error) {
      console.error(error);
      modalBody.innerHTML = '<p>Der Inhalt konnte gerade nicht geladen werden.</p>';
      modalBody.classList.add('content-visible');
    }
  }

  function closeNewsModal() {
    if (!modal || !modalBody) {
      return;
    }

    modal.classList.remove('show');
    modal.setAttribute('aria-hidden', 'true');
    modalBody.classList.remove('content-visible');
    document.body.style.overflow = '';
  }

  document.querySelectorAll('[data-modal-trigger]').forEach((trigger) => {
    trigger.addEventListener('click', () => openNewsModal(trigger));
  });

  document.querySelectorAll('[data-modal-close]').forEach((closeButton) => {
    closeButton.addEventListener('click', closeNewsModal);
  });

  document.addEventListener('keydown', (event) => {
    if (event.key === 'Escape') {
      closeNewsModal();
    }
  });
</script>

<style>
.news-page-intro {
  padding-bottom: 0;
}

.calendar-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
  gap: 1.25rem;
}

.calendar-month {
  padding: 1.35rem;
  border-radius: 26px;
  background: var(--color-surface);
  border: 1px solid var(--color-border-light);
  box-shadow: var(--shadow-sm);
}

.calendar-month-header h3 {
  margin-bottom: 1rem;
}

.calendar-weekdays,
.calendar-week {
  display: grid;
  grid-template-columns: repeat(7, minmax(0, 1fr));
  gap: 0.45rem;
}

.calendar-weekdays {
  margin-bottom: 0.6rem;
  color: var(--color-text-muted);
  font-size: 0.82rem;
  font-weight: 800;
  text-transform: uppercase;
}

.calendar-weeks {
  display: grid;
  gap: 0.45rem;
}

.calendar-day {
  min-height: 7rem;
  padding: 0.5rem;
  border-radius: 18px;
  background: rgba(54, 88, 66, 0.04);
  border: 1px solid transparent;
}

.calendar-day-active {
  border-color: var(--color-border-light);
}

.calendar-day-number {
  display: block;
  margin-bottom: 0.35rem;
  font-size: 0.88rem;
  font-weight: 800;
  color: var(--color-primary-dark);
}

.calendar-day-empty {
  opacity: 0;
}

.calendar-entry {
  display: grid;
  gap: 0.2rem;
  width: 100%;
  margin-top: 0.35rem;
  padding: 0.45rem 0.55rem;
  border: 0;
  border-radius: 14px;
  text-align: left;
  text-decoration: none;
  background: rgba(86, 112, 79, 0.09);
  color: var(--color-text-primary);
  cursor: pointer;
}

.calendar-entry strong {
  font-size: 0.82rem;
}

.calendar-entry span {
  font-size: 0.72rem;
  line-height: 1.35;
  color: var(--color-text-secondary);
}

.news-card-button {
  font: inherit;
  text-align: left;
  border: 1px solid var(--color-border-light);
  background: var(--color-surface);
}

.news-card-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 0.5rem;
  align-items: center;
  margin-bottom: 0.75rem;
}

.news-mode-tag {
  display: inline-flex;
  padding: 0.3rem 0.7rem;
  border-radius: 999px;
  background: rgba(188, 162, 112, 0.15);
  color: var(--color-primary-dark);
  font-size: 0.8rem;
  font-weight: 800;
  letter-spacing: 0.04em;
  text-transform: uppercase;
}

.event-location {
  font-size: 0.95rem;
  font-weight: 700;
  color: var(--color-text-muted);
}

.modal-location {
  margin-top: 0;
  margin-bottom: 1rem;
  font-size: 0.98rem;
  font-weight: 700;
  color: var(--color-text-muted);
}

.modal-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 0.75rem;
  margin-bottom: 1.5rem;
}

.tone-moss {
  border-left: 4px solid #56704f;
}

.tone-sage {
  border-left: 4px solid #90a388;
}

.tone-gold {
  border-left: 4px solid #bca270;
}

@media (max-width: 768px) {
  .calendar-day {
    min-height: 6rem;
  }
}
</style>
